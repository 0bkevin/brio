# Optional local overrides read by the root Makefile.
BRIO_ADDR=127.0.0.1:8787
BRIO_RELAY_ADDR=127.0.0.1:8082
BRIO_RELAY_URL=http://127.0.0.1:8082
BRIO_AGENT_ID=local-brio
HERMES_API_BASE=http://127.0.0.1:8642

# Optional companion settings.
# BRIO_PUBLIC_URL=http://127.0.0.1:8787
# BRIO_TOKEN=replace-with-a-local-dev-token
# HERMES_API_KEY=replace-with-hermes-api-key
# HERMES_HOME=/Users/you/.hermes
# BRIO_ALLOWED_ROOTS=/Users/you/projects,/Users/you/.hermes

# Optional relay persistence. If unset, the relay uses in-memory storage.
# BRIO_DATABASE_URL=postgres://user:password@localhost:5432/brio?sslmode=disable
